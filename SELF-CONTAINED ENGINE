def brier_score(pred, actual):
    return float(np.mean(np.sum((pred - actual) ** 2, axis=1)))

def seat_accuracy(pred, actual, parties):
    return sum(
        get_winner(p, parties) == get_winner(a, parties)
        for p, a in zip(pred, actual)
    ) / len(pred)


