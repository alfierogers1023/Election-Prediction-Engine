def fetch_hoc_results():
    # pulls the HoC Library results CSV - covers every election back to 1918
    # returns None if it fails (we fall back to synthetic data)
    url = ("https://researchbriefings.files.parliament.uk/documents/"
           "CBP-7529/HoC-GE-results-by-constituency-1918-2024.csv")
    headers = {
        "User-Agent": (
            "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
            "AppleWebKit/537.36 (KHTML, like Gecko) "
            "Chrome/120.0.0.0 Safari/537.36"
        ),
        "Accept": "text/csv,text/plain,*/*",
        "Referer": "https://researchbriefings.files.parliament.uk/",
    }
    try:
        resp = requests.get(url, headers=headers, timeout=90, stream=True)
        resp.raise_for_status()
        return pd.read_csv(StringIO(resp.text), encoding="latin-1", low_memory=False)
    except Exception as exc:
        print(f"  HoC Library: {exc}")
        return None


def parse_hoc_results(df):
    # cleans up the HoC file - column names vary a lot between years
    # normalises vote totals so everything is a fraction summing to 1
    df = df.copy()
    df.columns = [c.strip().upper().replace(" ", "_") for c in df.columns]

    year_col = next((c for c in df.columns if "YEAR" in c or "ELECT" in c), None)
    if year_col:
        df["year"] = pd.to_numeric(
            df[year_col].astype(str).str[:4], errors="coerce"
        )
        df = df[df["year"].isin(ELECTIONS)].copy()

    # Map varied column names to our standard party codes
    col_map = {
        "CON": "CON", "LAB": "LAB", "LD": "LDM", "LIB_DEM": "LDM",
        "LIBDEM": "LDM", "SNP": "SNP", "GRN": "GRN", "GREEN": "GRN",
        "PC": "PC", "PLAID": "PC", "UKIP": "REF", "REFORM": "REF",
        "REF_UK": "REF", "BREXIT": "REF",
    }
    for raw, std in col_map.items():
        if raw in df.columns and std not in df.columns:
            df[std] = df[raw]

    all_parties = GB_PARTIES + NI_PARTIES
    for p in all_parties:
        if p not in df.columns:
            df[p] = 0.0

    # Detect whether figures are raw votes or percentages
    vote_cols = [p for p in GB_PARTIES if p in df.columns]
    if df[vote_cols].sum(axis=1).mean() > 5:
        row_totals = df[vote_cols].sum(axis=1).replace(0, 1)
        df[vote_cols] = df[vote_cols].div(row_totals, axis=0)

    # Region
    region_col = next((c for c in df.columns if "REGION" in c or "COUNTRY" in c), None)
    df["region"] = df[region_col].fillna("England") if region_col else "England"
    df["is_ni"]  = df["region"].str.lower().str.contains("ireland", na=False)

    df["constituency_id"] = (
        df.get("CONSTITUENCY_NAME", df.index.astype(str))
    )

    return df


def fetch_nomis_table(table_id, geography="TYPE499", measures="20100",
                      extra_params=""):
    # fetches a census table from the Nomis API
    # geography TYPE499 = all Westminster constituencies
    base = "https://www.nomisweb.co.uk/api/v01/dataset"
    url  = (
        f"{base}/{table_id}.data.csv"
        f"?geography={geography}&measures={measures}"
        f"&select=GEOGRAPHY_CODE,GEOGRAPHY_NAME,C_UNIT_NAME,OBS_VALUE"
        f"{extra_params}"
    )
    try:
        resp = requests.get(url, timeout=40)
        if resp.status_code == 200 and len(resp.content) > 500:
            return pd.read_csv(StringIO(resp.text))
    except Exception:
        pass
    return None


