        a_m  = map_est["alpha_global"]
        ro_m = map_est["region_offset"]
        mu_m = (a_m[None, :]
                + data_2024_gb["X"] @ b_m
                + ro_m[data_2024_gb["region_idx"], :])
        mu_f = np.concatenate([mu_m, np.zeros((n_gb, 1))], axis=1)

        v24_act_f   = np.clip(data_2024_gb["votes"], 1e-6, 1)
        v24_act_f  /= v24_act_f.sum(axis=1, keepdims=True)
        log_v24_f   = np.log(v24_act_f)
        log_v24_f  -= log_v24_f.max(axis=1, keepdims=True)
        party_d_f   = np.array([SWING_DAMPEN_BY_PARTY.get(p, SWING_DAMPEN) for p in GB_PARTIES])
        nat_swing_f = log_ratio_swing * party_d_f
        theta_map_f = softmax(mu_f, axis=1)
        log_tm_f    = np.log(np.clip(theta_map_f, 1e-6, 1))
        log_tm_f   -= log_tm_f.mean(axis=0, keepdims=True)

        n_samples  = 800
        theta_post = np.zeros((n_gb, n_samples, N_GB))
        for s in range(n_samples):
                noise          = np.random.normal(0, SWING_SIGMA, (n_gb, N_GB))
                dev            = np.random.normal(0, 0.02, (n_gb, N_GB))
                log_f          = log_v24_f + nat_swing_f[None, :] + log_tm_f * 0.30 + dev + noise
                theta_post[:, s, :] = softmax(log_f, axis=1)

        forecast_mrp_gb_raw = theta_post.mean(axis=1)
        forecast_std_gb     = theta_post.std(axis=1)
        raked = forecast_mrp_gb_raw.copy()
        for _ in range(30):
            cm    = raked.mean(axis=0)
            scale = np.where(cm > 1e-9, polling_gb_vec / cm, 1.0)
            raked = raked * scale[None, :]
            raked = np.clip(raked, 1e-9, None)
            raked = raked / raked.sum(axis=1, keepdims=True)
        forecast_mrp_gb = raked

    except Exception as e2:
        print(f"  MAP also failed ({e2}) â proportional UNS baseline")
        log_base = np.log(np.clip(data_2024_gb["votes"], 1e-6, 1))
        log_base -= log_base.max(axis=1, keepdims=True)
        party_d_f = np.array([SWING_DAMPEN_BY_PARTY.get(p, SWING_DAMPEN) for p in GB_PARTIES])
