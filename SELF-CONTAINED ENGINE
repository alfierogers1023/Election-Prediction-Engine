ELECTORAL_SIGMA = 0.04  # 4pp â empirical UK constituency forecast error

def make_kappa_electoral(mrp, electoral_sigma=ELECTORAL_SIGMA):
    """
    Dirichlet concentration calibrated to empirical UK electoral uncertainty.
    Independent of NUTS posterior std â prevents near-deterministic draws.
    """
    leading = mrp.max(axis=1)                     # leading share per constituency
    kappa   = np.clip(
        leading * (1 - leading) / (electoral_sigma**2),
        a_min=8, a_max=250
    )
    return np.clip(mrp * kappa[:, None], 0.005, None)

