                    for p in (NI_PARTIES if is_ni else GB_PARTIES):
                        row[p] = shares[p]
                    for p in (GB_PARTIES if is_ni else NI_PARTIES):
                        row[p] = 0.0

                    for feat, val in demo.iloc[i].items():
                        row[feat] = float(val)
                    rows.append(row)
                    count += 1

    print(f"  built {count} rows")
    return pd.DataFrame(rows)


