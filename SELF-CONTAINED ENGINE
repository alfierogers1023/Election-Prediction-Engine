def build_election_dataset(hoc_df):
    # main data build function
    # uses real HoC results if we could download them, synthetic otherwise
    # demographics from Nomis if available, estimates from regional averages if not
    np.random.seed(42)

    if hoc_df is not None:
        df = parse_hoc_results(hoc_df)
    else:
        df = build_synthetic_results()

    # Attach demographics
    if nomis_demo is not None:
        df = df.merge(nomis_demo, on="constituency_id", how="left")

    # Fill missing demographics with regional synthetics
    missing_mask = df[DEMO_FEATURES[0]].isna()
    if missing_mask.any():
        for region, grp in df[missing_mask].groupby("region"):
            synth = make_synthetic_demographics(len(grp), region)
            synth.index = grp.index
            df.loc[grp.index, DEMO_FEATURES] = synth.values

    return df


