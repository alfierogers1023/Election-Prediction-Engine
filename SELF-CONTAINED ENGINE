def zscore_features(df, cols):
    df, params = df.copy(), {}
    for c in cols:
        mu, sigma = df[c].mean(), df[c].std() or 1.0
        df[c]     = (df[c] - mu) / sigma
        params[c] = (mu, sigma)
    return df, params


def encode_regions(df, region_list):
    idx = {r: i for i, r in enumerate(region_list)}
    df  = df.copy()
    df["region_idx"] = df["region"].map(idx).fillna(0).astype(int)
    return df, idx


