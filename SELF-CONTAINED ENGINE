# ---- bayesian MRP model ----

def build_mrp_model(X, votes, region_idx, n_regions, parties):
    """
    Hierarchical Bayesian Multinomial MRP model.
    Works for any party list (GB or NI).
    """
    n_obs     = X.shape[0]
    n_parties = len(parties)
    n_feat    = X.shape[1]
    coords    = {
        "party":      parties[:-1],
        "party_full": parties,
        "feature":    DEMO_FEATURES,
        "obs":        np.arange(n_obs),
        "region":     np.arange(n_regions),
    }
    with pm.Model(coords=coords) as model:
        X_data      = pm.Data("X",          X,          dims=("obs","feature"))
        region_data = pm.Data("region_idx", region_idx, dims="obs")

        alpha_global      = pm.Normal("alpha_global", mu=0, sigma=1,   dims="party")
        beta              = pm.Normal("beta",          mu=0, sigma=0.5, dims=("feature","party"))
        sigma_region      = pm.HalfNormal("sigma_region", sigma=0.3,   dims="party")
        region_offset_raw = pm.Normal("region_offset_raw", mu=0, sigma=1,
                                      dims=("region","party"))
        region_offset     = pm.Deterministic(
            "region_offset",
            region_offset_raw * sigma_region[None, :],
            dims=("region","party")
        )
        mu       = (alpha_global[None, :]
                    + pm.math.dot(X_data, beta)
                    + region_offset[region_data, :])
        zero_col = pt.zeros((mu.shape[0], 1))
        mu_full  = pt.concatenate([mu, zero_col], axis=1)
        theta    = pt_softmax(mu_full, axis=1)
        # Scalar concentration â Exponential(lam=0.05) gives prior mean 20.
        # This is well-calibrated for constituency-level vote share data.
        # Minor party seat variation comes from geographic data, not kappa.
        # lam=0.02 â prior mean 50, allows realistic constituency variance
        # for geographically concentrated parties (LDM, SNP, GRN)
        kappa = pm.Exponential("kappa", lam=0.02)
        pm.Dirichlet("obs_votes",
                     a=theta * kappa,
                     observed=np.clip(votes, 1e-6, 1),
                     dims=("obs","party_full"))
    return model


