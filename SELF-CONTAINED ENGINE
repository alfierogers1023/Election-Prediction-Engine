                        noise_scale = 0.10 if p in ("SNP", "LDM", "PC") else (
                                      0.08 if p in ("GRN", "REF") else 0.06)
                        shares[p] = max(0.002, base * mult + rng.normal(0, noise_scale))

                    total_s = sum(shares.values())
                    shares  = {p: v / total_s for p, v in shares.items()}

                    row = {
                        "year":            year,
                        "constituency_id": f"{region.replace(' ', '_')}_{i+1:03d}",
                        "region":          region,
                        "is_ni":           is_ni,
