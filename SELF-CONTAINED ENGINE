def fetch_polling():
    # scrapes the latest polls from the Wikipedia polling tracker
    # had to fiddle with the column name matching because Wikipedia formats keep changing
    global POLLING_DATE
    url = (
        "https://en.wikipedia.org/wiki/"
        "Opinion_polling_for_the_next_United_Kingdom_general_election"
    )
    col_map = {
        "lab": "LAB", "con": "CON", "ld": "LDM", "lib": "LDM",
        "reform": "REF", "green": "GRN", "snp": "SNP", "pc": "PC",
        "plaid": "PC",
    }
    try:
        resp   = requests.get(url, timeout=25,
                              headers={"User-Agent": "Mozilla/5.0"})
        tables = pd.read_html(StringIO(resp.text))
        for tbl in tables:
            col_lower = [str(c).lower() for c in tbl.columns]
            if sum(any(p in c for p in col_map) for c in col_lower) < 3:
                continue
            row = tbl.iloc[0]
            scraped = {}
            for raw_col, party in col_map.items():
                matches = [c for c in tbl.columns
                           if raw_col in str(c).lower()]
                if matches:
                    try:
                        val = float(
                            str(row[matches[0]]).replace("%", "").strip()
                        )
                        if val > 1:
                            val /= 100
                        scraped[party] = val
                    except (ValueError, TypeError):
                        pass
            if len(scraped) >= 4:
                for p in GB_PARTIES:
                    scraped.setdefault(p, 0.005)
                total    = sum(scraped[p] for p in GB_PARTIES)
                result   = {p: scraped[p] / total for p in GB_PARTIES}
                # Try to read the date from the first column
                try:
                    POLLING_DATE = str(tbl.iloc[0, 0])
                except Exception:
                    POLLING_DATE = "latest (Wikipedia)"
                return result, POLLING_DATE
    except Exception as exc:
        print(f"  Polling scrape failed: {exc}")
    return GB_POLLING.copy(), POLLING_DATE


def fetch_democracy_club():
    # Democracy Club tracks who is actually standing in each seat
    # useful for zeroing out parties not fielding a candidate somewhere
    url  = ("https://candidates.democracyclub.org.uk/api/next/candidates/"
            "?format=json&page_size=200")
    data = {}
    try:
        while url:
            resp = requests.get(url, timeout=20,
                                headers={"User-Agent": "python-mrp/1.0"})
            payload = resp.json()
            for result in payload.get("results", []):
                seat  = (result.get("ballot", {})
                               .get("post", {})
                               .get("label", ""))
                party = (result.get("party", {})
                               .get("legacy_slug", "").upper())
                if seat:
                    data.setdefault(seat, []).append(party)
            url = payload.get("next")
    except Exception:
        pass
    return data


